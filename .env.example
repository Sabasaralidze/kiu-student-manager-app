APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# If artisan fails on OneDrive, uncomment and adjust paths (Windows):
# If OneDrive blocks storage writes, uncomment and adjust paths (Windows):
# APP_PACKAGES_CACHE=\Users\YOUR_USER\AppData\Local\Temp\kiu-student-manager-packages.php
# APP_SERVICES_CACHE=\Users\YOUR_USER\AppData\Local\Temp\kiu-student-manager-services.php
# VIEW_COMPILED_PATH=C:\Users\YOUR_USER\AppData\Local\Temp\kiu-student-manager-views
# DB_DATABASE=C:\Users\YOUR_USER\AppData\Local\Temp\kiu-student-manager.sqlite
# LOG_PATH=C:\Users\YOUR_USER\AppData\Local\Temp\kiu-student-manager-laravel.log

# Seconds between password reset requests (use 15 for local testing)
AUTH_PASSWORD_RESET_THROTTLE=60

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# log = emails saved to storage/logs/laravel.log (no real inbox)
# smtp = real emails (Gmail example below)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="your@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
